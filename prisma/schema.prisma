generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          Int      @id @default(autoincrement())
  telegramId String   @unique
  username    String?
  firstName   String?
  lastName    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  channels Channel[]
  drafts   Draft[]
}

model Channel {
  id          Int      @id @default(autoincrement())
  ownerId     Int
  telegramId  String
  title       String
  username    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  owner User @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  drafts Draft[]
  posts  Post[]
  scheduledPosts ScheduledPost[]
  subscriberEvents SubscriberEvent[]
  subscriberSnapshots SubscriberSnapshot[]

  @@unique([ownerId, telegramId])
}

model Draft {
  id        Int      @id @default(autoincrement())
  userId    Int
  channelId Int?
  type      String   @default("text")
  text      String?
  fileId    String?
  caption   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  channel Channel? @relation(fields: [channelId], references: [id], onDelete: SetNull)
}

model Post {
  id                Int       @id @default(autoincrement())
  channelId         Int
  telegramMessageId Int?
  type              String    @default("text")
  text              String?
  fileId            String?
  caption           String?
  status            String    @default("published")
  createdAt         DateTime  @default(now())
  publishedAt       DateTime?

  channel Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@index([channelId, publishedAt])
}

model ScheduledPost {
  id          Int       @id @default(autoincrement())
  channelId   Int
  type        String    @default("text")
  text        String?
  fileId      String?
  caption     String?
  status      String    @default("pending")
  scheduledAt DateTime
  createdAt   DateTime  @default(now())
  publishedAt DateTime?

  channel Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@index([status, scheduledAt])
}

model SubscriberEvent {
  id                 Int      @id @default(autoincrement())
  channelId          Int
  telegramUserId     String
  username           String?
  firstName          String?
  lastName           String?
  eventType          String
  oldStatus          String?
  newStatus          String?
  createdAt          DateTime @default(now())

  channel Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@index([channelId, eventType, createdAt])
  @@index([telegramUserId])
}

model SubscriberSnapshot {
  id              Int      @id @default(autoincrement())
  channelId       Int
  subscriberCount Int
  createdAt       DateTime @default(now())

  channel Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@index([channelId, createdAt])
}
