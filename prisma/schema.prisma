generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          Int      @id @default(autoincrement())
  telegramId String   @unique
  username    String?
  firstName   String?
  lastName    String?
  createdAt   DateTime @default(now())
  updatedAt                 DateTime @updatedAt
  defaultReminderMinutes    Int      @default(30)
  notificationsEnabled      Boolean  @default(true)
  confirmBeforePublish      Boolean  @default(true)
  defaultCategory           String?
  onboardingCompleted       Boolean  @default(false)
  notifyOnSuccess           Boolean  @default(false)
  notifyOnFailure           Boolean  @default(true)

  channels         Channel[]
  drafts           Draft[]
  contentTemplates ContentTemplate[]
  feedbackItems    Feedback[]
}

model Channel {
  id          Int      @id @default(autoincrement())
  ownerId     Int
  telegramId  String
  title       String
  username    String?
  createdAt   DateTime @default(now())
  updatedAt      DateTime  @updatedAt
  isActive      Boolean   @default(true)
  disconnectedAt       DateTime?
  lastPermissionCheckAt DateTime?
  lastPermissionOk      Boolean?
  lastPermissionSummary String?

  owner User @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  drafts Draft[]
  posts  Post[]
  scheduledPosts ScheduledPost[]
  subscriberEvents SubscriberEvent[]
  subscriberSnapshots SubscriberSnapshot[]
  analyticsSnapshots  AnalyticsSnapshot[]

  @@unique([ownerId, telegramId])
  @@index([ownerId, isActive])
}

model Draft {
  id        Int      @id @default(autoincrement())
  userId    Int
  channelId Int?
  type      String   @default("text")
  text      String?
  fileId    String?
  caption   String?
  category  String?
  status    String   @default("draft")
  publishingStartedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  channel Channel? @relation(fields: [channelId], references: [id], onDelete: SetNull)
}

model Post {
  id                Int       @id @default(autoincrement())
  channelId         Int
  telegramMessageId Int?
  type              String    @default("text")
  text              String?
  fileId            String?
  caption           String?
  category          String?
  status            String    @default("published")
  createdAt         DateTime  @default(now())
  publishedAt       DateTime?

  channel Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@index([channelId, publishedAt])
}

model ScheduledPost {
  id              Int       @id @default(autoincrement())
  channelId       Int
  type            String    @default("text")
  text            String?
  fileId          String?
  caption         String?
  category        String?
  status          String    @default("pending")
  scheduledAt     DateTime
  recurrence      String    @default("none")
  recurrenceUntil DateTime?
  reminderMinutes Int       @default(30)
  reminderSentAt  DateTime?
  failureReason       String?
  attemptCount        Int       @default(0)
  lastAttemptAt       DateTime?
  processingStartedAt DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  publishedAt     DateTime?

  channel Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@index([status, scheduledAt])
  @@index([channelId, status, scheduledAt])
}

model SubscriberEvent {
  id                 Int      @id @default(autoincrement())
  channelId          Int
  telegramUserId     String
  username           String?
  firstName          String?
  lastName           String?
  eventType          String
  oldStatus          String?
  newStatus          String?
  createdAt          DateTime @default(now())

  channel Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@index([channelId, eventType, createdAt])
  @@index([telegramUserId])
}

model SubscriberSnapshot {
  id              Int      @id @default(autoincrement())
  channelId       Int
  subscriberCount Int
  createdAt       DateTime @default(now())

  channel Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@index([channelId, createdAt])
}

model AnalyticsSnapshot {
  id              Int      @id @default(autoincrement())
  channelId       Int
  subscriberCount Int
  postCount       Int      @default(0)
  scheduledCount  Int      @default(0)
  draftCount      Int      @default(0)
  source          String   @default("scheduler")
  createdAt       DateTime @default(now())

  channel Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@index([channelId, createdAt])
}


model ContentTemplate {
  id        Int      @id @default(autoincrement())
  userId    Int
  name      String
  type      String   @default("text")
  text      String?
  fileId    String?
  caption   String?
  category  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, updatedAt])
}

model Feedback {
  id        Int      @id @default(autoincrement())
  userId    Int
  type      String   @default("idea")
  message   String
  status    String   @default("new")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status, createdAt])
  @@index([userId, createdAt])
}
